# === NexusAgent Configuration ===

# API
API_HOST=0.0.0.0
API_PORT=8000
API_SECRET_KEY=change-me-in-production

# Database
DATABASE_URL=postgresql+asyncpg://nexus:nexus@localhost:5432/nexus_agent

# Redis
REDIS_URL=redis://localhost:6379/0

# LLM Providers (configurar al menos uno)
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=deepseek-r1:14b
DEFAULT_LLM_PROVIDER=ollama
DEFAULT_LLM_MODEL=deepseek-r1:14b

# MiniMax (para usuarios con Coding Plan)
MINIMAX_API_KEY=
MINIMAX_MODEL=MiniMax-Text-01

# RapiBase (base de datos — github.com/kitecosmic/rapibase)
RAPIBASE_URL=http://localhost:3500
RAPIBASE_API_KEY=

# Audio / Transcripción de voz
# Provider: "ollama" (local, usa whisper via Ollama) | "openai" (usa OpenAI Whisper API)
AUDIO_TRANSCRIPTION_PROVIDER=ollama
OLLAMA_WHISPER_MODEL=whisper

# Browser Module
BROWSER_HEADLESS=true
BROWSER_TIMEOUT=30000
BROWSER_MAX_CONCURRENT=5

# Messaging Bridge (para tu app de mensajería)
MESSAGING_WEBHOOK_URL=http://localhost:3000/webhook
MESSAGING_WEBHOOK_SECRET=your-webhook-secret
MESSAGING_WS_ENABLED=true

# Telegram
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# System Module (shell, files, packages)
SYSTEM_ALLOWED_ROOT=~
SYSTEM_COMMAND_TIMEOUT=30
SYSTEM_MAX_OUTPUT=10000

# MCP (Model Context Protocol) — servidores externos
# JSON array de servidores. Ejemplo con Playwright MCP:
# MCP_SERVERS=[{"name": "playwright", "command": "npx", "args": ["@playwright/mcp@latest"]}]
#
# Cloudflare MCP (crear/gestionar subdominios para UIs de apps):
# MCP_SERVERS=[{"name":"cloudflare","command":"npx","args":["@cloudflare/mcp-server-cloudflare@latest"],"env":{"CLOUDFLARE_API_TOKEN":"your-cf-api-token"}}]
#
# Ambos juntos:
# MCP_SERVERS=[{"name":"playwright","command":"npx","args":["@playwright/mcp@latest"]},{"name":"cloudflare","command":"npx","args":["@cloudflare/mcp-server-cloudflare@latest"],"env":{"CLOUDFLARE_API_TOKEN":"your-cf-api-token"}}]
MCP_SERVERS=

# Plugins
PLUGINS_DIR=plugins
PLUGINS_HOT_RELOAD=true

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Audio
AUDIO_TRANSCRIPTION_PROVIDER=#openai
